{
  "name": "zefer-cli",
  "version": "1.0.0",
  "description": "CLI for Zefer — AES-256-GCM file and text encryption",
  "type": "module",
  "bin": {
    "zefer": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "os": ["linux", "darwin", "win32"],
  "cpu": ["x64", "arm64", "ia32"],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
