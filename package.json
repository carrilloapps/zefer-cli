{
  "name": "zefer-cli",
  "version": "1.0.0",
  "description": "CLI for Zefer — AES-256-GCM file and text encryption. Official CLI companion to zefer.carrillo.app.",
  "type": "module",
  "bin": {
    "zefer": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "zefer",
    "encryption",
    "decrypt",
    "encrypt",
    "aes-256-gcm",
    "pbkdf2",
    "cli",
    "security",
    "crypto",
    "file-encryption",
    "text-encryption",
    "ink",
    "terminal",
    "offline",
    "zero-knowledge"
  ],
  "author": {
    "name": "Jose Carrillo",
    "email": "m@carrillo.app",
    "url": "https://carrillo.app"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carrilloapps/zefer-cli.git"
  },
  "homepage": "https://github.com/carrilloapps/zefer-cli#readme",
  "bugs": {
    "url": "https://github.com/carrilloapps/zefer-cli/issues"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64",
    "ia32"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
